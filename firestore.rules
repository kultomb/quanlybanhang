rules_version = '2';

/**
 * POS / Hangho — triển khai: `firebase deploy --only firestore:rules`
 *
 * - users/{uid}: chủ tài khoản đọc được hồ sơ của mình; ghi chỉ qua Admin SDK / Cloud Functions.
 * - shops/{shopId}: chỉ owner đọc được; không cho đoán shopId của người khác (read fail nếu không phải owner).
 * - Collection rate / security khác: client không truy cập (chỉ server).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /shops/{shopId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /_security_login_rate/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
