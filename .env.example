# --- Vercel: Project → Settings → Environment Variables ---
# Production: bắt buộc HTTPS, không dùng localhost.
# Dùng cho link continue sau email đặt lại mật khẩu (hangho.com / reset-password).
NEXT_PUBLIC_APP_URL=https://hangho.com

# Tùy chọn — tên thương hiệu trong thông báo (mặc định code: Hangho)
NEXT_PUBLIC_SITE_BRAND=Hangho

# Các biến NEXT_PUBLIC_FIREBASE_* và bí mật server — xem Firebase Console / tài liệu triển khai.
