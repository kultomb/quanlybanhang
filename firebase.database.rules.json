{
  "rules": {
    ".read": false,
    ".write": false,
    "paymentEvents": {
      ".read": false,
      ".write": false
    },
    "paymentWebhookIngest": {
      ".read": false,
      ".write": false
    },
    "users": {
      ".indexOn": ["paymentStatus", "paymentRef"],
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false,
        "shopDisplayName": {
          ".write": "auth != null && auth.uid === $uid && root.child('users').child($uid).child('email').exists()",
          ".validate": "newData.isString() && newData.val().length <= 400"
        },
        "lastSeen": {
          ".write": "auth != null && auth.uid === $uid && root.child('users').child($uid).child('email').exists()",
          ".validate": "newData.isNumber() && newData.val() > 1577836800000"
        }
      }
    },
    "shops": {
      "$shopSlug": {
        ".read": "auth != null && $shopSlug.matches(/^[a-z0-9-]{3,30}$/) && data.exists() && data.child('ownerUid').val() === auth.uid",
        ".write": false
      }
    },
    "trialShops": {
      "$shopSlug": {
        ".read": "auth != null && $shopSlug.matches(/^[a-z0-9-]{3,30}$/) && data.exists() && ( (data.child('ownerUid').exists() && data.child('ownerUid').val() === auth.uid) || (data.child('upgradedTo').exists() && root.child('users').child(auth.uid).child('shopSlug').val() === data.child('upgradedTo').val()) )",
        ".write": false
      }
    },
    "backups": {
      "$shopKey": {
        ".read": "auth != null && $shopKey.matches(/^shop_[a-z0-9-]{3,30}$/) && root.child('shops').child($shopKey.replace('shop_', '')).child('ownerUid').val() === auth.uid",
        ".write": "auth != null && $shopKey.matches(/^shop_[a-z0-9-]{3,30}$/) && root.child('shops').child($shopKey.replace('shop_', '')).child('ownerUid').val() === auth.uid"
      }
    },
    "trial_backups": {
      "$shopKey": {
        ".read": "auth != null && $shopKey.matches(/^shop_[a-z0-9-]{3,30}$/) && ( root.child('trialShops').child($shopKey.replace('shop_', '')).child('ownerUid').val() === auth.uid || ( root.child('trialShops').child($shopKey.replace('shop_', '')).child('upgradedTo').exists() && root.child('users').child(auth.uid).child('shopSlug').val() === root.child('trialShops').child($shopKey.replace('shop_', '')).child('upgradedTo').val() ) )",
        ".write": "auth != null && $shopKey.matches(/^shop_[a-z0-9-]{3,30}$/) && ( root.child('trialShops').child($shopKey.replace('shop_', '')).child('ownerUid').val() === auth.uid || ( root.child('trialShops').child($shopKey.replace('shop_', '')).child('upgradedTo').exists() && root.child('users').child(auth.uid).child('shopSlug').val() === root.child('trialShops').child($shopKey.replace('shop_', '')).child('upgradedTo').val() ) )"
      }
    }
  }
}
